datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Tier {
  FREE
  PRO
  ENTERPRISE
}

enum BetStatus {
  PENDING
  WON
  LOST
  VOID
  CASHED_OUT
}

enum Currency {
  USD
  EUR
  GBP
}

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  displayName          String?
  tier                 Tier      @default(FREE)
  defaultKellyFraction Decimal   @default(0.25) @db.Decimal(5, 4)
  bets                 Bet[]
  bankroll             Bankroll?
  apiKeys              ApiKey[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([tier])
}

model Bankroll {
  id         String    @id @default(uuid())
  userId     String    @unique
  amount     Decimal   @db.Decimal(14, 2)
  currency   Currency  @default(USD)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([currency])
}

model ApiKey {
  id          String    @id @default(uuid())
  userId      String
  keyHash     String    @unique
  label       String?
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, revokedAt])
}

model Prediction {
  id          String   @id @default(uuid())
  matchId     String   @unique
  homeTeam    String
  awayTeam    String
  modelProb   Float
  marketOdds  Float
  edge        Float
  commenceAt  DateTime
}

model Bet {
  id         String     @id @default(uuid())
  userId     String
  stake      Decimal    @db.Decimal(14, 2)
  odds       Decimal    @db.Decimal(10, 4)
  status     BetStatus  @default(PENDING)
  currency   Currency   @default(USD)
  placedAt   DateTime   @default(now())
  settledAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([userId, placedAt(sort: Desc)])
}
